    <!-- ==================== TAB BAR ==================== -->
    <nav class="tab-bar" id="tabBar">
      <div class="tab-item active" data-page="home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="tab-label">首页</span>
      </div>
      <div class="tab-item" data-page="order">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span class="tab-label">订货</span>
      </div>
      <div class="tab-item" data-page="profile">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="tab-label">我的</span>
      </div>
    </nav>
  </div>

  <script>
    // ===== Tab Navigation =====
    const tabItems = document.querySelectorAll('.tab-item');
    const pcNavLinks = document.querySelectorAll('.pc-nav-link');
    const pages = {
      home: document.getElementById('page-home'),
      order: document.getElementById('page-order'),
      profile: document.getElementById('page-profile'),
    };

    function switchPage(pageId) {
      Object.values(pages).forEach(p => p.classList.remove('active'));
      if (pages[pageId]) pages[pageId].classList.add('active');
      // Update mobile tabs
      tabItems.forEach(tab => {
        tab.classList.toggle('active', tab.dataset.page === pageId);
      });
      // Update PC nav links
      pcNavLinks.forEach(link => {
        link.classList.toggle('active', link.dataset.page === pageId);
      });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    tabItems.forEach(tab => {
      tab.addEventListener('click', () => {
        switchPage(tab.dataset.page);
      });
    });

    pcNavLinks.forEach(link => {
      link.addEventListener('click', () => {
        switchPage(link.dataset.page);
      });
    });

    // ===== Order Category Filter =====
    const orderTabs = document.querySelectorAll('.order-tab');
    const orderItems = document.querySelectorAll('.order-item');

    orderTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        orderTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        const cat = tab.dataset.cat;
        orderItems.forEach(item => {
          if (cat === 'all' || item.dataset.category === cat) {
            item.style.display = 'flex';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    // ===== Click Handlers =====
    document.querySelectorAll('.oi-btn, .banner-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        alert('功能开发中，敬请期待！');
      });
    });

    document.querySelectorAll('.product-card, .quick-cat, .section-more').forEach(el => {
      el.addEventListener('click', () => {
        alert('功能开发中，敬请期待！');
      });
    });

    document.querySelectorAll('.profile-menu-item').forEach(item => {
      item.addEventListener('click', () => {
        alert('功能开发中，敬请期待！');
      });
    });

    document.querySelector('.profile-header .profile-top').addEventListener('click', () => {
      alert('登录 / 注册功能开发中，敬请期待！');
    });
  // ============ 从后端 API 加载实时商品 ============
  (async function loadApiProducts() {
    const statusEl = document.getElementById('apiStatus');
    const gridEl = document.getElementById('apiProducts');
    try {
      const resp = await fetch('https://be.zuishe.com.cn/api/products');
      const json = await resp.json();
      if (!json.success || !json.data || json.data.length === 0) {
        statusEl.textContent = '⚠ 无数据';
        gridEl.innerHTML = '<div class="product-card" style="grid-column:1/-1;text-align:center;color:#999;padding:20px;">暂无商品数据</div>';
        return;
      }
      statusEl.textContent = '✓ 实时同步';
      const bgClasses = ['', 'red-bg', 'beer-bg', 'wine-bg', 'green-bg'];
      gridEl.innerHTML = json.data.map((p, i) => {
        const bg = bgClasses[i % bgClasses.length];
        return `
          <div class="product-card">
            <div class="pc-img ${bg}">
              <span>🍶</span>
              <span class="pc-tag hot">ID:${p.id}</span>
            </div>
            <div class="pc-body">
              <div class="pc-title">${p.spu_name || '商品'}</div>
              <div class="pc-spec">${p.alcohol_content ? p.alcohol_content + '° · ' : ''}${p.unit || '件'}</div>
              <div class="pc-bottom">
                <span class="pc-price" style="color:#999;font-size:12px;">后端数据 · 实时</span>
              </div>
            </div>
          </div>
        `;
      }).join('');
    } catch (err) {
      statusEl.textContent = '✗ 加载失败';
      gridEl.innerHTML = '<div class="product-card" style="grid-column:1/-1;text-align:center;color:#c62828;padding:20px;">后端 API 调用失败：' + (err.message || err) + '</div>';
      console.error('API load error:', err);
    }
  })();

</script>
</body>
</html>
