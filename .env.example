# zuishe.com.cn 环境变量模板
# 复制本文件为 .env，然后填入真实值
# 真实 .env 文件包含敏感密码，永远不要提交到 Git

# ===== PostgreSQL 数据库 =====
POSTGRES_DB=zsdb
POSTGRES_USER=zsdb
POSTGRES_PASSWORD=请改成你的强密码

# ===== Backend 后端 =====
BACKEND_PORT=3000

# ===== Caddy 反向代理 =====
# Let's Encrypt 申请证书时用的联系邮箱
CADDY_ADMIN_EMAIL=your-email@example.com

# ===== pgAdmin =====
PGADMIN_EMAIL=your-pgadmin-login@example.com
PGADMIN_PW=请改成另一个强密码（不要和数据库相同）