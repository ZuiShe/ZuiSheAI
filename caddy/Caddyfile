# Caddy 配置：自动 HTTPS + 反向代理

# 全局设置
{
    email {$CADDY_ADMIN_EMAIL}
}

# ========== 前端 H5 ==========
app.zuishe.com.cn {
    encode gzip zstd
    reverse_proxy frontend:80
}

# ========== 后端 API ==========
be.zuishe.com.cn {
    encode gzip zstd
    reverse_proxy backend:3000
}

# ========== 数据库管理工具（pgAdmin）==========
db.zuishe.com.cn {
    encode gzip zstd
    reverse_proxy pgadmin:80
}